@namespace BlazorPdf

<div class="nbp-native @CssClass">
    @if (ShowToolbar)
    {
        <div class="nbp-toolbar" role="toolbar" aria-label="PDF toolbar">
            <div class="nbp-group">
                <button type="button" class="nbp-btn" title="Previous page"
                        @onclick="PreviousAsync" disabled="@(_pageIndex <= 0)">
                    @PdfIcons.ChevronLeft
                </button>
                <span class="nbp-page">@CurrentPage / @PageCount</span>
                <button type="button" class="nbp-btn" title="Next page"
                        @onclick="NextAsync" disabled="@(_document is null || _pageIndex >= _document.PageCount - 1)">
                    @PdfIcons.ChevronRight
                </button>
            </div>

            <div class="nbp-spacer"></div>

            <div class="nbp-group">
                <button type="button" class="nbp-btn" title="Zoom out" @onclick="() => ZoomAsync(0.8)">−</button>
                <span class="nbp-page">@($"{_scale * 100:0}%")</span>
                <button type="button" class="nbp-btn" title="Zoom in" @onclick="() => ZoomAsync(1.25)">+</button>
            </div>
        </div>
    }

    <div class="nbp-canvas-wrap" style="height:@Height">
        @if (_error is not null)
        {
            <div class="nbp-error">Render error: @_error</div>
        }
        else if (_document is null)
        {
            <div class="nbp-empty">No document loaded.</div>
        }
        <canvas @ref="_canvas" class="nbp-canvas"></canvas>
    </div>
</div>
