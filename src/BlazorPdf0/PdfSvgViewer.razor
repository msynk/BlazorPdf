@namespace BlazorPdf

<div class="nbp-svg @CssClass">
    @if (ShowToolbar)
    {
        <div class="nbp-toolbar" role="toolbar" aria-label="PDF toolbar">
            <div class="nbp-group">
                <button type="button" class="nbp-btn" title="Previous page"
                        @onclick="Previous" disabled="@(_pageIndex <= 0)">
                    @PdfIcons.ChevronLeft
                </button>
                <span class="nbp-page">@CurrentPage / @PageCount</span>
                <button type="button" class="nbp-btn" title="Next page"
                        @onclick="Next" disabled="@(_document is null || _pageIndex >= _document.PageCount - 1)">
                    @PdfIcons.ChevronRight
                </button>
            </div>

            <div class="nbp-spacer"></div>

            <div class="nbp-group">
                <button type="button" class="nbp-btn" title="Zoom out" @onclick="ZoomOut">−</button>
                <span class="nbp-page">@($"{_zoom * 100:0}%")</span>
                <button type="button" class="nbp-btn" title="Zoom in" @onclick="ZoomIn">+</button>
            </div>
        </div>
    }

    <div class="nbp-svg-scroll" style="height:@Height">
        @if (_error is not null)
        {
            <div class="nbp-error">Render error: @_error</div>
        }
        else if (_document is null)
        {
            <div class="nbp-empty">No document loaded.</div>
        }
        else
        {
            <div class="nbp-svg-page"
                 style="width:@(Css(_pageWidth * _zoom))px;height:@(Css(_pageHeight * _zoom))px">
                @_svg
            </div>
        }
    </div>
</div>

@code {
    private static string Css(double v) => v.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
}
