@namespace BlazorPdf

<div @ref="_container"
     class="nbp-viewer @CssClass"
     style="width:@Width;height:@Height;@Style"
     @attributes="AdditionalAttributes">

    @if (ShowToolbar)
    {
        <div class="nbp-toolbar" role="toolbar" aria-label="PDF toolbar">
            @if (ShowPageNavigation)
            {
                <div class="nbp-group">
                    <button type="button" class="nbp-btn" title="Previous page"
                            @onclick="PreviousPageAsync" disabled="@(_currentPage <= 1)">
                        @PdfIcons.ChevronLeft
                    </button>
                    <span class="nbp-page" aria-live="polite">Page @_currentPage</span>
                    <button type="button" class="nbp-btn" title="Next page" @onclick="NextPageAsync">
                        @PdfIcons.ChevronRight
                    </button>
                </div>
            }

            <div class="nbp-spacer"></div>

            @if (ToolbarContent is not null)
            {
                <div class="nbp-group">@ToolbarContent</div>
            }

            <div class="nbp-group">
                @if (ShowPrintButton)
                {
                    <button type="button" class="nbp-btn" title="Print" @onclick="PrintAsync">
                        @PdfIcons.Print
                    </button>
                }
                @if (ShowDownloadButton)
                {
                    <button type="button" class="nbp-btn" title="Download" @onclick="DownloadAsync">
                        @PdfIcons.Download
                    </button>
                }
                @if (ShowOpenInNewTabButton)
                {
                    <button type="button" class="nbp-btn" title="Open in new tab" @onclick="OpenInNewTabAsync">
                        @PdfIcons.NewTab
                    </button>
                }
                @if (ShowFullscreenButton)
                {
                    <button type="button" class="nbp-btn" title="Fullscreen" @onclick="ToggleFullscreenAsync">
                        @PdfIcons.Fullscreen
                    </button>
                }
            </div>
        </div>
    }

    <div class="nbp-frame-wrap">
        @if (_currentSource is null)
        {
            <div class="nbp-empty">No document loaded.</div>
        }
        <iframe @ref="_iframe"
                class="nbp-frame"
                title="PDF document"
                src="about:blank"></iframe>
    </div>
</div>
