@page "/"
@rendermode InteractiveServer

<PageTitle>BlazorPdf demo</PageTitle>

<div class="page">
    <h1>BlazorPdf</h1>
    <p>A pure-C# PDF viewer for Blazor that renders PDF pages to plain DOM elements.</p>

    <div class="controls">
        <button @onclick="LoadGeneratedBytes">Load generated PDF</button>

        <label class="upload">
            Upload a PDF
            <InputFile OnChange="LoadUploaded" accept="application/pdf" />
        </label>

        <label class="option" title="Paint pages onto a per-page canvas (pdf.js style) instead of positioned DOM. Selection, search and links stay DOM either way.">
            Renderer
            <select @onchange="OnRenderModeChanged">
                <option value="Html" selected="@(!_canvasMode)">HTML</option>
                <option value="Canvas" selected="@_canvasMode">Canvas</option>
            </select>
        </label>

        <label class="option" title="Merge same-line text runs into one span per line — far fewer DOM nodes on per-glyph PDFs, with kerning between runs approximated. (HTML renderer only.)">
            <input type="checkbox" checked="@_compactText" @onchange="OnCompactTextChanged" disabled="@_canvasMode" />
            Compact text spans
        </label>

        <span class="status">@_status</span>
    </div>

    <BlazorPdfViewer Source="_source"
                     Height="800px"
                     InitialZoomMode="PdfZoomMode.FitWidth"
                     RenderMode="@(_canvasMode ? PdfRenderMode.Canvas : PdfRenderMode.Html)"
                     TextCoalescing="@(_compactText ? PdfTextCoalescing.Compact : PdfTextCoalescing.Exact)"
                     OnDocumentLoaded="OnLoaded"
                     OnError="OnViewerError" />
</div>

@code {
    private PdfSource? _source;
    private string _status = "Pick a source above.";
    private bool _compactText;
    private bool _canvasMode;

    private void OnCompactTextChanged(ChangeEventArgs e)
    {
        _compactText = e.Value is true;
        _status = _compactText
            ? "Compact text: one span per line."
            : "Exact text: one span per run.";
    }

    private void OnRenderModeChanged(ChangeEventArgs e)
    {
        _canvasMode = e.Value?.ToString() == "Canvas";
        _status = _canvasMode
            ? "Canvas renderer: pages painted onto <canvas>."
            : "HTML renderer: pages rendered as positioned DOM.";
    }

    protected override void OnInitialized()
        => _source = PdfSource.FromBytes(SamplePdf.Build(pages: 3), "sample.pdf");

    private void LoadGeneratedBytes()
    {
        _source = PdfSource.FromBytes(SamplePdf.Build(pages: 5, title: "Generated"), "generated.pdf");
        _status = "Loaded 5-page generated PDF.";
    }

    private void OnLoaded() => _status = "Document loaded.";

    private void OnViewerError(string message) => _status = $"Error: {message}";

    private async Task LoadUploaded(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        using var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
        using var memory = new MemoryStream();
        await stream.CopyToAsync(memory);
        _source = PdfSource.FromBytes(memory.ToArray(), file.Name);
        _status = $"Loaded {file.Name}.";
    }
}
