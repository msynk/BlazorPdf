@namespace BlazorPdf
@using System.Globalization
@using BlazorPdf.Core

<div class="blazorpdf-viewer" style="height:@Height" @ref="_viewerRef">
    @if (_loading)
    {
        <div class="blazorpdf-progress" role="progressbar" aria-label="Loading document">
            <div class="blazorpdf-progress-bar"></div>
        </div>
    }
    @if (ShowToolbar)
    {
        <div class="blazorpdf-toolbar">
            <div class="blazorpdf-group">
                <button class="blazorpdf-btn @(_showThumbnails ? "active" : "")" title="Pages" @onclick="ToggleThumbnails" disabled="@(_pages.Count == 0)">
                    <svg viewBox="0 0 24 24"><path d="M4 4h7v7H4zM13 4h7v7h-7zM4 13h7v7H4zM13 13h7v7h-7z"/></svg>
                </button>
                <button class="blazorpdf-btn @(_showOutline ? "active" : "")" title="Bookmarks" @onclick="ToggleOutline" disabled="@(!HasOutline)">
                    <svg viewBox="0 0 24 24"><path d="M6 3h12v18l-6-4-6 4z"/></svg>
                </button>
            </div>

            <div class="blazorpdf-group">
                <button class="blazorpdf-btn" title="Previous page" @onclick="PrevPage" disabled="@(_currentPage <= 1)">
                    <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
                </button>
                <input class="blazorpdf-page-input" type="number" min="1" max="@_pages.Count"
                       value="@_currentPage" @onchange="OnPageInput" disabled="@(_pages.Count == 0)" />
                <span class="blazorpdf-page-total">/ @_pages.Count</span>
                <button class="blazorpdf-btn" title="Next page" @onclick="NextPage" disabled="@(_currentPage >= _pages.Count)">
                    <svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
                </button>
            </div>

            <div class="blazorpdf-group">
                <button class="blazorpdf-btn" title="Zoom out" @onclick="ZoomOut" disabled="@(_pages.Count == 0)">
                    <svg viewBox="0 0 24 24"><path d="M5 12h14"/></svg>
                </button>
                <span class="blazorpdf-zoom">@((int)Math.Round(_zoom * 100))%</span>
                <button class="blazorpdf-btn" title="Zoom in" @onclick="ZoomIn" disabled="@(_pages.Count == 0)">
                    <svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
                </button>
                <select class="blazorpdf-select" @onchange="OnFitChanged" disabled="@(_pages.Count == 0)">
                    @if (_zoomMode == PdfZoomMode.Custom)
                    {
                        <option value="Custom" selected>@((int)Math.Round(_zoom * 100))%</option>
                    }
                    <option value="FitWidth" selected="@(_zoomMode == PdfZoomMode.FitWidth)">Fit width</option>
                    <option value="FitPage" selected="@(_zoomMode == PdfZoomMode.FitPage)">Fit page</option>
                    <option value="ActualSize" selected="@(_zoomMode == PdfZoomMode.ActualSize)">100%</option>
                </select>
            </div>

            <div class="blazorpdf-title">@(_source?.FileName ?? "BlazorPdf")</div>

            <div class="blazorpdf-group blazorpdf-right">
                @if (_showSearch)
                {
                    <div class="blazorpdf-search-box">
                        <input class="blazorpdf-search-input" type="search" placeholder="Find in document"
                               value="@_searchQuery" @onchange="OnSearchInput" @onkeydown="OnSearchKeyDown"
                               disabled="@(_pages.Count == 0)" />
                        <span class="blazorpdf-search-count">@SearchLabel</span>
                        <button class="blazorpdf-btn" title="Previous match" @onclick="SearchPrev" disabled="@(_searchTotal <= 0)">
                            <svg viewBox="0 0 24 24"><path d="M6 15l6-6 6 6"/></svg>
                        </button>
                        <button class="blazorpdf-btn" title="Next match" @onclick="SearchNext" disabled="@(_searchTotal <= 0)">
                            <svg viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>
                        </button>
                    </div>
                }
                <button class="blazorpdf-btn @(_showSearch ? "active" : "")" title="Find" @onclick="ToggleSearch" disabled="@(_pages.Count == 0)">
                    <svg viewBox="0 0 24 24"><circle cx="10.5" cy="10.5" r="6.5"/><path d="M20 20l-4.9-4.9"/></svg>
                </button>
                <button class="blazorpdf-btn" title="Rotate" @onclick="RotateClockwise" disabled="@(_pages.Count == 0)">
                    <svg viewBox="0 0 24 24"><path d="M21 12a9 9 0 1 1-3-6.7M21 4v5h-5"/></svg>
                </button>
                <button class="blazorpdf-btn" title="Download" @onclick="DownloadAsync" disabled="@(_source?.Bytes is null)">
                    <svg viewBox="0 0 24 24"><path d="M12 3v12M7 10l5 5 5-5M5 21h14"/></svg>
                </button>
                <button class="blazorpdf-btn" title="Print" @onclick="PrintAsync" disabled="@(_pages.Count == 0)">
                    <svg viewBox="0 0 24 24"><path d="M6 9V3h12v6M6 18H4v-7h16v7h-2M8 14h8v7H8z"/></svg>
                </button>
                <button class="blazorpdf-btn" title="Fullscreen" @onclick="ToggleFullscreen">
                    <svg viewBox="0 0 24 24"><path d="M4 9V4h5M20 9V4h-5M4 15v5h5M20 15v5h-5"/></svg>
                </button>
            </div>
        </div>
    }

    <div class="blazorpdf-body">
        @if (_showOutline && HasOutline)
        {
            <div class="blazorpdf-outline">
                @RenderOutline(_outline)
            </div>
        }
        @if (_showThumbnails && _pages.Count > 0)
        {
            <div class="blazorpdf-thumbs">
                @for (int i = 0; i < _pages.Count; i++)
                {
                    int pageNo = i + 1;
                    <div class="blazorpdf-thumb @(pageNo == _currentPage ? "active" : "")" @onclick="() => GoToPage(pageNo)">
                        <div class="blazorpdf-thumb-svg" style="@ThumbStyle(i)">
                            @if (_pages[i] is { } thumb)
                            {
                                @thumb
                            }
                        </div>
                        <span class="blazorpdf-thumb-label">@pageNo</span>
                    </div>
                }
            </div>
        }

        <div class="blazorpdf-surface" @ref="_containerRef">
            @if (_source is null)
            {
                <div class="blazorpdf-empty">No document loaded.</div>
            }
            else if (_pages.Count == 0)
            {
                <div class="blazorpdf-empty">@_status</div>
            }
            else
            {
                <div class="blazorpdf-pages">
                    @for (int i = 0; i < _pages.Count; i++)
                    {
                        <div class="blazorpdf-page" data-page="@(i + 1)" style="@PageStyle(i)">
                            @if (_pages[i] is { } content)
                            {
                                @content
                            }
                            else
                            {
                                <div class="blazorpdf-page-placeholder"></div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    private async Task OnFitChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<PdfZoomMode>(e.Value?.ToString(), out var mode))
        {
            await SetZoomMode(mode);
        }
    }

    private RenderFragment RenderOutline(IReadOnlyList<OutlineItem> items) =>
        @<ul class="blazorpdf-outline-list">
            @foreach (var item in items)
            {
                <li>
                    <div class="blazorpdf-outline-item @(item.PageNumber is null ? "disabled" : "")"
                         title="@item.Title" @onclick="@(() => OnOutlineClick(item))">@item.Title</div>
                    @if (item.Children.Count > 0)
                    {
                        @RenderOutline(item.Children)
                    }
                </li>
            }
        </ul>;
}
